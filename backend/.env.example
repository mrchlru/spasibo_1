# Скопируйте в backend/.env и подставьте реальные значения. Не коммитьте .env.

ADMIN_API_KEY="your-admin-api-key"
ADMIN_EMAILS="admin@yourdomain.ru"
JWT_SECRET_KEY="generate-a-long-random-string"

SMTP_HOST="smtp.timeweb.ru"
SMTP_PORT=465
SMTP_USE_TLS=false
SMTP_USERNAME="noreply@yourdomain.ru"
# Если в пароле есть \, удвойте его внутри двойных кавычек: "abc\\-xyz"
SMTP_PASSWORD="your-smtp-password"

TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID=-1000000000000
# Остальные TELEGRAM_* — по необходимости, см. config/settings

WEB_APP_LOGIN_URL="https://your-frontend.example"

# Почта и SMTP на Timeweb Apps: см. TIMEWEB_EMAIL_SETUP.md в корне репозитория
