# Скопируйте в backend/.env и подставьте реальные значения. Не коммитьте .env.

ADMIN_API_KEY="your-admin-api-key"
# Через запятую: уведомления + разрешённые email для входа в админ-панель (см. ADMIN_PANEL_PASSWORD)
ADMIN_EMAILS="admin@yourdomain.ru"
ADMIN_PANEL_PASSWORD=""
JWT_SECRET_KEY="generate-a-long-random-string"

SMTP_HOST="smtp.timeweb.ru"
SMTP_PORT=465
SMTP_USE_TLS=false
SMTP_USERNAME="noreply@yourdomain.ru"
# Если в пароле есть \, удвойте его внутри двойных кавычек: "abc\\-xyz"
SMTP_PASSWORD="your-smtp-password"

TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID=-1000000000000
# Опционально: внешний relay для исходящих Telegram API-запросов
# (например Railway вне РФ). Если пусто — приложение ходит в api.telegram.org напрямую.
TELEGRAM_RELAY_URL="https://your-telegram-relay.up.railway.app"
TELEGRAM_RELAY_SECRET="change-me"
# Остальные TELEGRAM_* — по необходимости, см. config/settings
#
# Кнопки «Принять/Отказать» в Telegram: бот и API в одном процессе (uvicorn).
# Нужно один раз назначить webhook на этот сервис (HTTPS):
#   APP_PUBLIC_URL="https://ваш-публичный-домен.example"  # без / в конце
#   см. deploy/set-telegram-webhook.sh (set | info | delete)

WEB_APP_LOGIN_URL="https://your-frontend.example"

# Почта и SMTP на Timeweb Apps: см. TIMEWEB_EMAIL_SETUP.md в корне репозитория

# PostgreSQL (продакшен)
# DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# Фоновая синхронизация «источник (Railway) → DATABASE_URL (Timeweb)»: backend/dual_database_sync.py
# Первый успешный цикл — UPSERT всех строк; в таблице dual_db_sync_state ставится флаг, далее только новые PK каждые N с.
# Повторить полный копирование: UPDATE dual_db_sync_state SET initial_full_sync_done = false WHERE id = 1;
# SYNC_SOURCE_DATABASE_URL="postgresql://...@....rlwy.net:5432/railway?sslmode=require"
# DB_SYNC_ENABLED=true
# DB_SYNC_INTERVAL_SECONDS=30
# DB_SYNC_BATCH_SIZE=200

# Одноразовая миграция Railway → Timeweb: deploy/pg_migrate_source_to_target.sh
# PG_MIGRATE_SOURCE_URL="postgresql://...@....rlwy.net:5432/railway?sslmode=require"
# PG_MIGRATE_CONFIRM=yes
# Опционально цель: PG_MIGRATE_TARGET_URL (иначе берётся DATABASE_URL)
# Перезапись цели: PG_MIGRATE_CLEAN=yes
